# TrainingAgent local configuration

# API Gateway
ENGINE_SERVICE_URL=http://localhost:8083
MARKET_SERVICE_URL=http://localhost:8082
SIGNAL_CACHE_SECONDS=60

# Optional dashboard auth. Leave empty for local open access.
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# Engine dependencies
NEWS_SERVICE_URL=http://localhost:8081
SIGNAL_MIN_PROBABILITY=0.58
DATABASE_URL=postgres://trainingagent:trainingagent@localhost:5432/trainingagent?sslmode=disable

# News RSS feeds, comma-separated
NEWS_FEEDS=https://cointelegraph.com/rss,https://decrypt.co/feed
NEWS_HTTP_TIMEOUT_SECONDS=10

# Market data
BINANCE_API_BASE=https://api.binance.com
BINANCE_HTTP_TIMEOUT_SECONDS=10
